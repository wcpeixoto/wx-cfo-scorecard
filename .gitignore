node_modules
dist
.vite
.DS_Store
.env
# local env files (.env.local, .env.<mode>.local) — never commit. Repo-owned so protection does
# not depend on a machine-global gitignore. .local-suffixed on purpose: keeps .env.example tracked.
.env*.local

# build/cache artifacts
*.tsbuildinfo
vite.config.d.ts

# scratch / archive workspace — local only
Temp/

# Supabase local state and secrets — never commit
supabase/.env
supabase/.env.local
supabase/.temp/

# financial PII docs — never commit (e.g. docs/Accts.pdf account statements)
docs/*.pdf

# local Wodify recon docs — contain member names (real PII); keep local, never publish to this public repo
/Wodify/
